# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ANTHROPIC_API_KEY: Optional. If provided, the system will use Claude 3.5 Sonnet to respond to chats.
# This gives you state-of-the-art responses aligned to your persona.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# META_VERIFY_TOKEN: Custom token used by Meta Developer Console to verify Webhook endpoints.
# If not provided, defaults to "caro_connect_token_2026".
META_VERIFY_TOKEN="caro_connect_token_2026"

# STRIPE_SECRET_KEY: Optional. If provided, the system will use real Stripe Checkout Sessions.
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: Optional. For verifying real Stripe webhook events in production.
STRIPE_WEBHOOK_SECRET=""

# GOOGLE_CLIENT_ID: Optional. For real Google Sign-In Integration.
GOOGLE_CLIENT_ID=""

# APPLE_CLIENT_ID: Optional. For real Sign in with Apple integration.
APPLE_CLIENT_ID=""


